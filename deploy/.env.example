# Copy to deploy/.env to enable automatic HTTPS.
#
# Set SITE_ADDRESS to the domain that points at this server (an A record →
# the instance's public IP). Caddy will fetch and renew a Let's Encrypt cert
# for it automatically and redirect http→https.
#
# Leave this file absent (or SITE_ADDRESS unset) to serve plain HTTP on :80.
SITE_ADDRESS=app.example.com
